┘ │       │\n    -0.2   D4          │ R6    │\n    -0.4 C3  R5        │   C4  │\n    -0.6   ┬           │       │\n    -0.8 ┬ │           │ ┬ ┬   │\n    -1.0 G │ ┬         └─┴─┴───┤\n    -1.2   └─┘                 G\n    \"\n  `)\n\n  expect(result.laidOutSchematicSvg).toMatchSvgSnapshot(import.meta.path)\n})\n","exitCode":0,"durationMs":0},"threadId":"019d2aaf-1cc7-73d0-9c45-616dc01c5a32","turnId":"019d2aaf-1ccc-7cf2-9773-3b18dd455489"}}
