onvertCircuitJsonToSchematicSvg(circuitJson, {\n93:         grid: { cellSize: 1, labelCells: true },\n94:       })\n95:       setOriginalSvg(originalSvgString)\n96: \n97:       // Apply layout pipeline\n98:       const inputNetlist = convertCircuitJsonToInputNetlist(circuitJson)\n99: \n100:       const solver = new SchematicLayoutPipelineSolver({\n101:         inputNetlist: inputNetlist,\n102:       })\n103:       await solver.solve()\n104: \n105:       const outputTemplate =\n106:         solver.adaptPhaseSolver!.outputAdaptedTemplates[0]?.template!\n107: \n108:       const newCircuitJson = applyCircuitLayoutToCircuitJson(\n109:         circuitJson,\n110:         inputNetlist,\n111:         outputTemplate,\n112:       )\n113: \n114:       // Generate layout SVG\n115:       const layoutSvgString = convertCircuitJsonToSchematicSvg(\n116:         newCircuitJson as any,\n117:         {\n118:           grid: { cellSize: 1, labelCells: true },\n119:         },\n120:       )\n121:       setLayoutSvg(layoutSvgString)\n122:     } catch (e) {\n123:       setError(e instanceof Error ? e.message : \"Unknown error occurred\")\n124:     } finally {\n125:       setIsLoading(false)\n126:     }\n127:   }\n128: \n129:   const handleCodeChange = (e: React.ChangeEvent<HTMLTextAreaElement>) => {\n130:     setCode(e.target.value)\n131:   }\n132: \n133:   const handleKeyDown = (e: React.KeyboardEvent) => {\n134:     if (e.key === \"Tab\") {\n135:       e.preventDefault()\n136:       const textarea = textareaRef.current\n137:       if (textarea) {\n138:         const start = textarea.selectionStart\n139:         const end = textarea.selectionEnd\n140:         const newValue = `${code.substring(0, start)}  ${code.substring(end)}`\n\n(Showing lines 1-140 of 353. Use offset=141 to continue.)\n</content>\n\n<system-reminder>\nInstructions from: /workspace/node_modules/@tscircuit/schematic-match-adapt/CLAUDE.md\n# CLAUDE.md\n\nThis file provides guidance to Claude Code (claude.ai/code) when working with code in this repository.\n\n## Common Commands\n\n**Testing**:\n\n- `bun test` - Run all tests\n- `bun test tests/path/to/test.test.ts` - Run specific test\n\n**Code Quality**:\n\n- `bun run format` - Format code with Biome\n- `bun run format:check` - Check formatting\n- No separate lint/typecheck commands - use TypeScript compiler directly\n\n**Development**:\n\n- `bun run generate-comments` - Generate template comments\n\n## Architecture Overview\n\nThis is a **PMARS** (Partition, Match, Adapt, Refine, Stitch) automatic schematic layout system for tscircuit. The pipeline transforms input netlists into positioned circuit layouts using pre-generated templates.\n\n### Core Pipeline\n\n- **Partition**: Split complex circuits (not implemented)\n- **Match**: `MatchPhaseSolver` → `SingleMatchSolver` finds best template match\n- **Adapt**: `AdaptPhaseSolver` modifies templates to fit input (stub implementation)\n- **Refine**: Optimize layouts (not implemented)\n- **Stitch**: Combine partitions (not implemented)\n\n### Key Components\n\n**Solvers** (`lib/solvers/`):\n\n- `SchematicLayoutPipelineSolver` - Main entry point, orchestrates PMARS pipeline\n- `BaseSolver` - Step-based execution framework with timing/progress\n- `SingleMatchSolver` - Template matching against input netlist\n\n**Builders** (`lib/builder/`):\n\n- `CircuitBuilder` - Primary API for constructing/modifying circuit templates\n- `ChipBuilder` - Individual component construction\n- Templates in `templates/` return `CircuitBuilder` instances\n\n**Data Flow**:\n\n1. `InputNetlist` (boxes, connections, nets) →\n2. Template matching against library →\n3. Edit operations to adapt template →\n4. Positioned circuit output\n\n### Testing Guidelines\n\n- One test per file, enumerate multiple tests: `myFunction01.test.ts`, `myFunction02.test.ts`\n- Start with `CircuitBuilder` user input\n- Use `.toMatchInlineSnapshot()` for input visualization, then test output verification\n- Prefer snapshots over small assertions\n\n### Important File Paths\n\n- `lib/input-types.ts` - Input data structures (`InputNetlist`, `Box`, `Connection`)\n- `lib/builder/circuit-types.ts` - Output circuit types (`Line`, `NetLabel`)\n- `lib/adapt/EditOperation.ts` - Template modification operations\n- `templates/` - Pre-built circuit layout templates\n- `tests/e2e/` - End-to-end pipeline tests\n\n## Writing Debug Scripts\n\nYou can create small scripts for debugging, use\n`bun` to run the scripts rather than `node`\n\ne.g. you could do `bun run debug_something.ts`\n\n## Solvers\n\n- Solver code can quickly get complex, do not create private methods or put\n  complex logic inside the `*Solver` classes. Instead create helper methods\n  inside the `lib/**/*` directory. For example, the `ScoreNetlistTemplatePairSolver`\n  imports utility functions from `lib/matching/matching-utils/*`.\n\n</system-reminder>","title":"workspace/node_modules/@tscircuit/schematic-match-adapt/website/pages/eval.page.tsx","metadata":{"preview":"import { useState, useEffect, useRef } from \"react\"\nimport { runTscircuitCode } from \"@tscircuit/eval\"\nimport { cju } from \"@tscircuit/circuit-json-util\"\nimport { convertCircuitJsonToSchematicSvg } from \"circuit-to-svg\"\nimport { convertCircuitJsonToInputNetlist } from \"../../lib/circuit-json/convertCircuitJsonToInputNetlist\"\nimport { CircuitBuilder } from \"../../lib/builder\"\nimport { applyCircuitLayoutToCircuitJson } from \"../../lib/circuit-json/applyCircuitLayoutToCircuitJson\"\nimport {\n  getBase64PoundSnippetString,\n  getUncompressedSnippetString,\n} from \"@tscircuit/create-snippet-url\"\nimport { SchematicLayoutPipelineSolver } from \"lib/solvers/SchematicLayoutPipelineSolver\"\nimport { normalizeNetlist } from \"lib/scoring/normalizeNetlist\"\n\nconst defaultCode = `import { sel } from \"tscircuit\"\n\nexport default () => (\n  <board routingDisabled>\n    <chip\n      name=\"U1\"","truncated":true,"loaded":["/workspace/node_modules/@tscircuit/schemati